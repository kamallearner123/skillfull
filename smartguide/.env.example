# SmartGuide — Environment Variables
# Copy to .env and fill in your values.

# ── LLM Engine ─────────────────────────────────────────────────────────────
# Options: vllm | llama_cpp | mock
LLM_BACKEND=mock

# HuggingFace model repo ID or local path
MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3

# For llama_cpp backend: local path to .gguf file inside the container
GGUF_MODEL_PATH=./models/mistral-7b-instruct-v0.3.Q4_K_M.gguf

# vLLM GPU settings
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=4096
TENSOR_PARALLEL_SIZE=1

# Generation
MAX_NEW_TOKENS=1024
TEMPERATURE=0.7
TOP_P=0.9

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/1
REDIS_TTL_SECONDS=86400

# ── Security ───────────────────────────────────────────────────────────────
# Shared secret between Django backend and SmartGuide
INTERNAL_API_KEY=change-me-in-production

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# ── RAG / Vector DB ─────────────────────────────────────────────────────────
# Sentence-transformers model for embedding (downloads automatically ~80MB)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Persistent ChromaDB directory (mounted as Docker volume for persistence)
CHROMA_PERSIST_DIR=./chroma_db

# Number of chunks to retrieve per query
RAG_TOP_K=5

# Set to false to globally disable RAG retrieval (e.g. for load testing)
RAG_ENABLED=true
